		"devdoc": {
			"details": "This design choice eliminates inheritance-based reentrancy risksBuilt on OpenZeppelin's battle-tested security foundations",
			"events": {
				"Approval(address,address,uint256)": {
					"details": "Emitted when the allowance of a `spender` for an `owner` is set by a call to {approve}. `value` is the new allowance."
				},
				"ChainDeploymentRegistered(uint256,bytes32)": {
					"params": {
						"chainId": "Chain ID where contract was deployed",
						"deploymentHash": "Hash of the deployment for verification"
					}
				},
				"ContractDeployed(string,string,bytes32,string)": {
					"params": {
						"abiHash": "Hash of contract ABI for verification",
						"features": "Security and functionality features",
						"standard": "Token standard implemented",
						"version": "Contract version"
					}
				},
				"Transfer(address,address,uint256)": {
					"details": "Emitted when `value` tokens are moved from one account (`from`) to another (`to`). Note that `value` may be zero."
				}
			},
			"kind": "dev",
			"methods": {
				"allowance(address,address)": {
					"details": "See {IERC20-allowance}."
				},
				"approve(address,uint256)": {
					"details": "Must zero existing allowance before setting new non-zero amountOverrides OpenZeppelin's approve to add race condition protection",
					"params": {
						"amount": "Amount to approve",
						"spender": "Address to approve"
					},
					"returns": {
						"_0": "True if approval succeeded"
					}
				},
				"balanceOf(address)": {
					"details": "See {IERC20-balanceOf}."
				},
				"burn(uint256)": {
					"details": "Burned tokens are permanently removed from circulationUses OpenZeppelin's burn implementation with Transfer event to address(0)",
					"params": {
						"amount": "Amount of tokens to burn permanently"
					}
				},
				"burnFrom(address,uint256)": {
					"details": "Requires sufficient allowance from token ownerProtected against reentrancy attacks using OpenZeppelin's ReentrancyGuard",
					"params": {
						"account": "Address to burn tokens from",
						"amount": "Amount of tokens to burn"
					}
				},
				"circulatingSupply()": {
					"details": "Alias function for better semantic clarity in DeFi applications",
					"returns": {
						"_0": "Current circulating supply (initial supply minus burned tokens)"
					}
				},
				"constructor": {
					"details": "initialHolder cannot be zero address, totalInitialSupply must be > 0",
					"params": {
						"initialHolder": "Address to receive initial token supply",
						"totalInitialSupply": "Total token supply for this deployment"
					}
				},
				"decimals()": {
					"details": "Returns the number of decimals used to get its user representation. For example, if `decimals` equals `2`, a balance of `505` tokens should be displayed to a user as `5.05` (`505 / 10 ** 2`). Tokens usually opt for a value of 18, imitating the relationship between Ether and Wei. This is the default value returned by this function, unless it's overridden. NOTE: This information is only used for _display_ purposes: it in no way affects any of the arithmetic of the contract, including {IERC20-balanceOf} and {IERC20-transfer}."
				},
				"decreaseAllowance(address,uint256)": {
					"details": "Enhanced version with explicit underflow check",
					"params": {
						"spender": "Address to decrease allowance for",
						"subtractedValue": "Amount to subtract from current allowance"
					},
					"returns": {
						"_0": "True if operation succeeded"
					}
				},
				"getBurnRate(uint256)": {
					"params": {
						"precision": "Decimal places for precision (e.g., 100 for 2 decimals)"
					},
					"returns": {
						"_0": "Burn rate with specified precision"
					}
				},
				"getChainName(uint256)": {
					"details": "Supports all 10 official BZR deployment chains",
					"params": {
						"chainId": "Chain ID to get name for"
					},
					"returns": {
						"_0": "Chain name string"
					}
				},
				"getContractMetadata()": {
					"details": "Implements ERC-5267 for automated contract introspection",
					"returns": {
						"abiHash": "Hash of contract ABI for verification",
						"description": "Detailed description of the token",
						"features": "Array of security and functionality features",
						"standard": "Token standard implemented",
						"tokenName": "Token name",
						"versionString": "Contract version  "
					}
				},
				"getDeploymentInfo()": {
					"returns": {
						"abiHash": "Hash of contract ABI for verification",
						"chainId": "Chain ID where contract was deployed",
						"deploymentHash": "Hash of deployment parameters",
						"deploymentTime": "Timestamp when contract was deployed"
					}
				},
				"getMultiChainInfo()": {
					"details": "Provides comprehensive multi-chain deployment tracking",
					"returns": {
						"allChains": "Array of all supported chain IDs",
						"currentChainId": "Current chain ID",
						"currentDeploymentHash": "Deployment hash for current chain",
						"totalChains": "Total number of supported chains"
					}
				},
				"getTokenStats()": {
					"details": "Provides all key supply metrics in a single call for efficiency",
					"returns": {
						"burnRate": "Burn rate in basis points (10000 = 100%)",
						"burnedTokens": "Total tokens burned",
						"currentSupply": "The current circulating supply (same as totalSupply)",
						"initialSupplyValue": "The initial token supply at deployment"
					}
				},
				"increaseAllowance(address,uint256)": {
					"details": "Uses OpenZeppelin's increaseAllowance implementation",
					"params": {
						"addedValue": "Amount to add to current allowance",
						"spender": "Address to increase allowance for"
